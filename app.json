{
  "expo": {
    "name": "Office Days",
    "slug": "officedays",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "notification": {
      "icon": "./assets/notification-icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCalendarsUsageDescription": "This app needs access to your calendar to log office days.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.officedays.app"
    },
    "android": {
      "package": "com.officedays.app",
      "versionCode": 1,
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Office Days to access your calendar to log office days."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4c9fd85f-65be-4a8b-a2a7-356283602e4b"
      }
    },
    "owner": "navinvarma"
  }
}
